# =============================================================================
# WeChat Mini-Program Security Audit Toolkit — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the actual values.
# The .env file is listed in .gitignore and will NOT be committed.

# API signing key (extracted from mini-program frontend common/config.js)
WXMINI_SIGN_KEY=your_sign_key_here

# Production API base URL
WXMINI_API_BASE=https://wxmini.api.bjadks.com/

# Default activity / institution IDs
WXMINI_ACT_ID=2092
WXMINI_CUS_ID=3824
